[Unit]
Description=Home Ventilation Automation
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@REPO_DIR@
ExecStart=@REPO_DIR@/.venv/bin/home-ventilation --config @REPO_DIR@/config.toml
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
